rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId}/reports/{reportId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if (request.auth != null && request.auth.uid == userId)
        || reportId.matches('CLI\\-.*');
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    match /users/{userId}/verifications/{reportId} {
      allow read, create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    match /users/{userId}/apiKeys/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /apiKeyIndex/{apiKey} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /publicReports/{reportId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    match /cliReports/{reportId} {
      allow read, write: if true;
    }

  }
}
